# ── Telegram (MTProto / Telethon) ─────────────────────────────────────────────
# Get from https://my.telegram.org → API Development Tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef
TELEGRAM_PHONE=+14155550123
TELEGRAM_SESSION=harvest_session

# ── LLM ───────────────────────────────────────────────────────────────────────
# Backend: "litellm" (cloud API) or "local" (RyzenAI NPU/GPU/CPU via interlock)
LLM_BACKEND=litellm
#
# -- litellm backend --
# Model in litellm format: gpt-4o-mini, anthropic/claude-3.5-haiku, etc.
LLM_MODEL=gpt-4o-mini
# Set the API key for your chosen provider:
OPENAI_API_KEY=sk-...
# Or for Anthropic: ANTHROPIC_API_KEY=sk-ant-...
# Or for OpenRouter: OPENROUTER_API_KEY=sk-or-v1-...
#
# -- local backend (requires ryzenai-python on PATH) --
# LLM_BACKEND=local
# LLM_MODEL_PATH=models/qwen2.5-7b-int4.onnx
# LLM_TOKENIZER_PATH=models/qwen2.5-7b-int4
# LLM_DEVICE=npu  # npu, gpu, or cpu

# ── TickTick ───────────────────────────────────────────────────────────────────
# 1. Go to https://developer.ticktick.com → Manage Apps → + App Name
# 2. Set OAuth Redirect URL to: http://127.0.0.1:8080
# 3. Copy Client ID and Client Secret below
TICKTICK_CLIENT_ID=your_client_id
TICKTICK_CLIENT_SECRET=your_client_secret
TICKTICK_REDIRECT_URI=http://127.0.0.1:8080
# Your normal TickTick login credentials
TICKTICK_USERNAME=you@example.com
TICKTICK_PASSWORD=yourpassword
# Optional: name of the TickTick project to create tasks in (uses Inbox if blank)
TICKTICK_PROJECT=

# ── Discord ───────────────────────────────────────────────────────────────────
# Optional: override auto-detected cache path
# DISCORD_CACHE_PATH=

# ── Gmail ─────────────────────────────────────────────────────────────────────
# Option A: base64-encoded JSON (preferred — no loose files)
#   python -c "import base64; print(base64.b64encode(open('credentials.json').read().encode()).decode())"
# GMAIL_CREDENTIALS_JSON=eyJ...
# GMAIL_TOKEN_JSON=eyJ...
#
# Option B: file paths (fallback)
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# ── Telegram filtering ────────────────────────────────────────────────────────
# Optional: comma-separated allowlist/blocklist of dialog names
# TELEGRAM_CHANNELS=work-chat,project-updates
# TELEGRAM_EXCLUDE=memes,random

# ── Obsidian output ───────────────────────────────────────────────────────────
# Directories for Obsidian-compatible markdown reports (date-stamped per run)
# OBSIDIAN_EVENTS_DIR=F:\path\to\vault\08 - Events Pool
# OBSIDIAN_RECRUITERS_DIR=F:\path\to\vault\08 - Events Pool\Recruiters

# ── Defaults ───────────────────────────────────────────────────────────────────
DAYS_BACK=7
